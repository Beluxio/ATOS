# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Modelo a usar (gpt-4.1-mini es el default, más barato)
OPENAI_MODEL=gpt-4.1-mini

# ── Base de datos ──────────────────────────────────────────────────────────────
# No cambies esto si usas docker-compose
DATABASE_URL=postgresql+asyncpg://atos:atos@db:5432/atos

# ── Seguridad JWT ──────────────────────────────────────────────────────────────
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_un_valor_seguro_generado

# ── Entorno ────────────────────────────────────────────────────────────────────
# "development" = CORS abierto (cualquier origen). "production" = CORS restringido.
ENVIRONMENT=production
# Orígenes permitidos (separados por coma). Solo aplica si ENVIRONMENT=production.
ALLOWED_ORIGINS=https://atos.beluxio.org,https://portal.beluxio.org

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Sin esta clave los emails no se envían (el sistema igual funciona)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dirección del remitente — debe usar un dominio verificado en Resend
EMAIL_FROM=ATOS Soporte <soporte@send.beluxio.org>
