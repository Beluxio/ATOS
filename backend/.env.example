OPENAI_API_KEY=your_openai_api_key_here
# Cambia el modelo según tu acceso: gpt-4.1-mini, gpt-4o-mini, gpt-5-mini, etc.
OPENAI_MODEL=gpt-4.1-mini
DATABASE_URL=postgresql+asyncpg://atos:atos@db:5432/atos
SECRET_KEY=cambia_esto_por_un_valor_seguro_generado
ENVIRONMENT=development
# Orígenes permitidos separados por coma
ALLOWED_ORIGINS=https://<tu-usuario>.github.io,http://localhost:5173,http://localhost:5500
